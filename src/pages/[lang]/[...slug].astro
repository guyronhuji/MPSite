---
import { getCollection, getEntry, render } from "astro:content";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { getUiCopy } from "../../lib/copy";
import { defaultLocale, isLocale, localeList, locales, type Locale } from "../../lib/i18n";
import { assetHref, pageHref } from "../../lib/routing";

export async function getStaticPaths() {
  const entries = await getCollection("pages");

  return entries.map((entry) => {
    const slugParam = entry.data.path === "home" ? undefined : entry.data.path;

    return {
      params: {
        lang: entry.data.lang,
        slug: slugParam,
      },
    };
  });
}

const langParam = Astro.params.lang;
if (!langParam || !isLocale(langParam)) {
  return Astro.redirect(pageHref(defaultLocale, "home"));
}

const localeCode = langParam as Locale;
const localeMeta = locales[localeCode];
const ui = getUiCopy(localeCode);
const currentPath = Astro.params.slug ?? "home";

const allPages = await getCollection("pages");
const entry = allPages.find((item) => item.data.lang === localeCode && item.data.path === currentPath);
const publicationsEntry = await getEntry("publications", "list");

const publications = (publicationsEntry?.data.items ?? [])
  .filter(
    (
      item,
    ): item is {
      id: string;
      year: number;
      status: "published" | "forthcoming";
      type: "book" | "edited_volume" | "chapter" | "article" | "other";
      title: string;
      authors: string;
      venue: string;
      details?: string;
      doi?: string;
      url?: string;
    } =>
      typeof item.id === "string" &&
      typeof item.year === "number" &&
      (item.status === "published" || item.status === "forthcoming" || item.status === undefined) &&
      (item.type === "book" ||
        item.type === "edited_volume" ||
        item.type === "chapter" ||
        item.type === "article" ||
        item.type === "other") &&
      typeof item.title === "string" &&
      typeof item.authors === "string" &&
      typeof item.venue === "string",
  )
  .map((item) => ({
    ...item,
    status: item.status ?? "published",
  }))
  .slice()
  .sort((a, b) => b.year - a.year);

if (!entry) {
  return Astro.redirect(pageHref(localeCode, "home"));
}

const allPagesInLang = allPages
  .filter((item) => item.data.lang === localeCode)
  .sort(
  (left, right) => left.data.order - right.data.order,
  );

const navEntries = allPagesInLang.filter((item) => item.data.showInNav);

const { Content } = await render(entry);

const currentSlug = currentPath;
const children = allPagesInLang.filter((candidate) => {
  if (candidate.id === entry.id) return false;
  if (currentSlug === "home") return false;
  if (!candidate.data.path.startsWith(`${currentSlug}/`)) return false;

  const remainingPath = candidate.data.path.replace(`${currentSlug}/`, "");
  return !remainingPath.includes("/");
});

const childCards = children.map((child) => ({
  title: child.data.title,
  summary: child.data.summary,
  href: pageHref(localeCode, child.data.path),
  image: child.data.heroImage ? assetHref(child.data.heroImage) : undefined,
  imageAlt: child.data.heroImageAlt ?? child.data.title,
}));

const languageLinks = localeList.map((code) => {
  const translated = allPages.find((item) => item.data.lang === code && item.data.path === currentSlug);

  return {
    code,
    href: translated ? pageHref(code, translated.data.path) : pageHref(code, "home"),
    available: Boolean(translated),
  };
});
const langBadge: Record<Locale, string> = {
  en: "En",
  he: "עב",
  ar: "عر",
  de: "De",
};

const title = `${entry.data.title} | Dr. Michal Peles-Almagor`;
const description = entry.data.summary ?? "Academic website scaffold";
const isHomePage = currentSlug === "home";
const isPublicationsPage = currentSlug === "publications";
const profileImageSrc = assetHref(entry.data.heroImage ?? "/uploads/michal-peles-almagor.jpg");
const profileImageAlt = entry.data.heroImageAlt ?? ui.portraitAlt;

const publicationGroup = (item: (typeof publications)[number]) => {
  if (item.status === "forthcoming") return "forthcoming";
  if (item.type === "book" || item.type === "edited_volume") return "books";
  if (item.type === "chapter") return "chapters";
  return "articles";
};

const publicationTypeLabel = (item: (typeof publications)[number]) => {
  if (item.status === "forthcoming") return ui.filterForthcoming;
  if (item.type === "book" || item.type === "edited_volume") return ui.filterBooks;
  if (item.type === "chapter") return ui.filterChapters;
  return ui.filterArticles;
};
---

<SiteLayout
  title={title}
  description={description}
  lang={localeCode}
  dir={localeMeta.dir}
  navEntries={navEntries}
  currentSlug={currentSlug}
>
  <article class="article-shell">
    <nav class="language-nav page-language-nav" aria-label={ui.languageNavAria}>
      {
        languageLinks.map((item) => (
          <a
            href={item.href}
            class:list={[
              "lang-link",
              item.code === localeCode && "active",
              !item.available && "fallback",
            ]}
            aria-current={item.code === localeCode ? "page" : undefined}
            title={locales[item.code].label}
          >
            {langBadge[item.code]}
          </a>
        ))
      }
    </nav>

    {
      isHomePage && (
        <section class="home-splash" aria-label={ui.portraitAlt}>
          <img
            src={profileImageSrc}
            alt={profileImageAlt}
            class="profile-photo"
            width="190"
            height="250"
            loading="eager"
          />
          <div class="intro-card">
            <p class="intro-tag">{ui.profileTag}</p>
            <p class="intro-title">{entry.data.title}</p>
          </div>
        </section>
      )
    }
    <header class="page-hero">
      <h1>{entry.data.title}</h1>
      {entry.data.summary && <p class="summary">{entry.data.summary}</p>}
    </header>

    <div class="article-body">
      <Content />

      {
        isPublicationsPage && publications.length > 0 && (
          <section class="publications-structured" aria-label={ui.publicationListAria}>
            <div class="pub-filter" data-pub-filter aria-label={ui.publicationFiltersAria}>
              <button type="button" class="pub-filter-btn active" data-filter="all">{ui.filterAll}</button>
              <button type="button" class="pub-filter-btn" data-filter="books">{ui.filterBooks}</button>
              <button type="button" class="pub-filter-btn" data-filter="articles">{ui.filterArticles}</button>
              <button type="button" class="pub-filter-btn" data-filter="chapters">{ui.filterChapters}</button>
              <button type="button" class="pub-filter-btn" data-filter="forthcoming">{ui.filterForthcoming}</button>
            </div>

            <ul class="publication-list" role="list" data-publication-list>
              {
                publications.map((item) => {
                  const group = publicationGroup(item);
                  return (
                    <li class:list={["publication-item", `type-${group}`, item.status === "forthcoming" && "is-forthcoming"]} data-type={group}>
                      <div class="publication-meta">
                        <span>{item.year}</span>
                        <span>·</span>
                        <span class:list={["pub-badge", group]}>{publicationTypeLabel(item)}</span>
                      </div>
                      <p class="publication-title">{item.title}</p>
                      <p class="publication-details">
                        {item.authors}. {item.venue}
                        {item.details ? ` ${item.details}` : ""}
                        {item.doi ? ` DOI: ${item.doi}` : ""}
                      </p>
                      {item.url ? <p class="publication-details"><a href={item.url} target="_blank" rel="noreferrer">{ui.publicationOpenLink}</a></p> : null}
                    </li>
                  );
                })
              }
            </ul>

            <script is:inline>
              (() => {
                const init = () => {
                  const sections = Array.from(document.querySelectorAll(".publications-structured"));
                  if (!sections.length) return;

                  sections.forEach((section) => {
                    if (section instanceof HTMLElement && section.dataset.pubReady === "true") return;
                    if (section instanceof HTMLElement) section.dataset.pubReady = "true";

                    const filterWrap = section.querySelector("[data-pub-filter]");
                    const list = section.querySelector("[data-publication-list]");
                    if (!filterWrap || !list) return;

                    const buttons = Array.from(filterWrap.querySelectorAll("[data-filter]"));
                    const items = Array.from(list.querySelectorAll("[data-type]"));

                    const applyFilter = (value) => {
                      items.forEach((item) => {
                        item.hidden = value !== "all" && item.dataset.type !== value;
                      });
                      buttons.forEach((btn) => {
                        btn.classList.toggle("active", btn.dataset.filter === value);
                      });
                    };

                    buttons.forEach((btn) => {
                      btn.addEventListener("click", () => applyFilter(btn.dataset.filter || "all"));
                    });

                    applyFilter("all");
                  });
                };

                if (document.readyState === "loading") {
                  document.addEventListener("DOMContentLoaded", init, { once: true });
                  return;
                }

                init();
              })();
            </script>
          </section>
        )
      }
    </div>

    {
      childCards.length > 0 && (
        <section class="children" aria-label={ui.relatedPagesAria}>
          <ul class="children-list">
            {
              childCards.map((child) => (
                <li class="children-card-item">
                  <a
                    href={child.href}
                    class:list={["children-card-link", child.image && "has-image"]}
                    style={child.image ? `--child-card-image: url('${child.image}');` : undefined}
                    aria-label={child.image ? `${child.title} — ${child.imageAlt}` : child.title}
                  >
                    <span class="children-card-overlay">
                      <span class="children-card-title">{child.title}</span>
                      {child.summary && <span class="children-card-summary">{child.summary}</span>}
                    </span>
                  </a>
                </li>
              ))
            }
          </ul>
        </section>
      )
    }
  </article>
</SiteLayout>
